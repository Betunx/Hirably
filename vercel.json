{
  "version": 2,
  "buildCommand": "ng build --configuration production --base-href /",
  "outputDirectory": "dist/hirably/browser",
  "headers": [
    {
      "source": "/index.html",
      "headers": [
        { "key": "cache-control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/:file*.(js|css|ico|png|jpg|jpeg|webp|svg|woff|woff2|ttf|eot|xml|txt)",
      "headers": [
        { "key": "cache-control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
