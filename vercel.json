{
  "version": 2,
  "buildCommand": "ng build --configuration production --base-href /",
  "outputDirectory": "dist/hirably/browser",
  "framework": null,
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "src": "/index.html",
      "headers": {
        "cache-control": "no-cache, no-store, must-revalidate"
      },
      "dest": "/index.html"
    },
    {
      "src": "/(.*\\.(js|css|ico|png|jpg|jpeg|webp|svg|woff|woff2|ttf|eot|xml|txt))",
      "headers": {
        "cache-control": "public, max-age=31536000, immutable"
      }
    },
    {
      "src": "/(.*)",
      "headers": {
        "cache-control": "no-cache, no-store, must-revalidate"
      },
      "dest": "/index.html"
    }
  ]
}
